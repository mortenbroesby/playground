{
  "summaryStrategy": "doc-comments-first",
  "observability": {
    "enabled": true
  },
  "performance": {
    "exclude": [
      "node_modules/**",
      "dist/**",
      "coverage/**",
      ".git/**",
      ".astrograph/**"
    ],
    "workerPool": {
      "enabled": true
    }
  },
  "watch": {
    "backend": "auto",
    "debounceMs": 100
  },
  "limits": {
    "maxFilesDiscovered": 100000,
    "maxFileBytes": 250000,
    "maxSymbolsPerFile": 2000
  }
}
