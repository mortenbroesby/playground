{
  "extends": "@playground/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@playground/ui": ["../../../packages/ui/src/index.ts"],
      "@playground/ui/*": ["../../../packages/ui/src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["./src", "./vite.config.ts"]
}
