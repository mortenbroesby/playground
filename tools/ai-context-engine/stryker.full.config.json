{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "reporters": ["clear-text", "progress", "html"],
  "htmlReporter": {
    "fileName": "coverage/stryker-full.html"
  },
  "tempDirName": ".stryker-tmp",
  "mutate": [
    "src/cli.ts:85-235",
    "src/config.ts:55-106",
    "src/mcp.ts:154-247",
    "src/mcp.ts:309-369",
    "src/storage.ts:833-842",
    "src/storage.ts:966-1144"
  ],
  "testFiles": [
    "tests/interface.test.ts",
    "tests/engine-behavior.test.ts"
  ],
  "ignorePatterns": [
    "coverage",
    "dist",
    ".astrograph",
    ".stryker-tmp"
  ],
  "vitest": {
    "related": true
  }
}
