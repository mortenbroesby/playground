{
  "name": "@playground/obsidian-memory",
  "version": "0.0.1",
  "private": true,
  "description": "Repo-local Obsidian memory indexing and retrieval tools",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "workspace-tools": "^0.41.4",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "scripts": {
    "obsidian:bootstrap": "node ./src/bootstrap-obsidian-vault.mjs",
    "rag:init": "node --experimental-strip-types ./src/rag-init.ts",
    "rag:index": "node --experimental-strip-types ./src/rag-index.ts",
    "rag:classify": "node ./src/rag-classify.mjs",
    "rag:clean": "node ./src/rag-clean.mjs",
    "rag:doctor": "node ./src/rag-doctor.mjs",
    "rag:evals": "node ./src/rag-retrieval-evals.mjs",
    "rag:fix-frontmatter": "node ./src/rag-fix-frontmatter.mjs",
    "rag:report": "node ./src/rag-report.mjs",
    "rag:query": "node ./src/rag-query.mjs",
    "rag:verify": "node ./src/verify-obsidian-rag.mjs",
    "rag:write": "node ./src/rag-write.mjs",
    "mcp": "node ./src/rag-mcp-server.mjs",
    "rag:test": "node --test ./tests/*.test.mjs",
    "test:retrieval": "node --test ./tests/*.test.mjs"
  }
}
