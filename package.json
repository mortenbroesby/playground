{
  "name": "playground",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "node scripts/dev-web.mjs",
    "lint": "turbo lint && pnpm lint:md",
    "lint:md": "markdownlint-cli2 \"README.md\" \"apps/*/README.md\" \"packages/*/README.md\" \"packages/*/*/README.md\"",
    "test:integration": "pnpm --filter @playground/todo-app test:integration",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "prepare": "husky",
    "mcp:validate": "node scripts/validate-mcp-config.mjs",
    "mcp:export:claude": "node scripts/export-mcp-config.mjs claude",
    "mcp:export:cursor": "node scripts/export-mcp-config.mjs cursor",
    "mcp:export:vscode": "node scripts/export-mcp-config.mjs vscode"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.17.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
