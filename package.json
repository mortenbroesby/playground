{
  "name": "playground",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "24.x",
    "pnpm": "9.15.9"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "node scripts/dev-web.mjs",
    "docs:check": "pnpm knowledge:check",
    "knowledge:check": "node scripts/check-knowledge-reminder.mjs",
    "lint": "turbo lint && pnpm lint:md",
    "lint:prepush": "node scripts/prepush-checks.mjs",
    "lint:md": "pnpm markdown:check",
    "markdown:fix": "markdownlint-cli2 \"README.md\" \"AGENTS.md\" \".github/copilot-instructions.md\" \"docs/*.md\" \"docs/ideas/**/*.md\" \"docs/obsidian/**/*.md\" \"vault/**/*.md\" \"apps/*/README.md\" \"packages/*/README.md\" \"packages/*/*/README.md\" \"tools/*/README.md\" --fix",
    "markdown:check": "markdownlint-cli2 \"README.md\" \"AGENTS.md\" \".github/copilot-instructions.md\" \"docs/*.md\" \"docs/ideas/**/*.md\" \"docs/obsidian/**/*.md\" \"vault/**/*.md\" \"apps/*/README.md\" \"packages/*/README.md\" \"packages/*/*/README.md\" \"tools/*/README.md\"",
    "obsidian:bootstrap": "pnpm --filter @playground/obsidian-memory obsidian:bootstrap",
    "obsidian:test-rag": "pnpm --filter @playground/obsidian-memory test:retrieval",
    "obsidian:verify-rag": "pnpm --filter @playground/obsidian-memory rag:verify",
    "rag:init": "pnpm --filter @playground/obsidian-memory rag:init",
    "rag:index": "pnpm --filter @playground/obsidian-memory rag:index",
    "rag:classify": "pnpm --filter @playground/obsidian-memory rag:classify",
    "rag:clean": "pnpm --filter @playground/obsidian-memory rag:clean",
    "rag:doctor": "pnpm --filter @playground/obsidian-memory rag:doctor",
    "rag:fix-frontmatter": "pnpm --filter @playground/obsidian-memory rag:fix-frontmatter",
    "rag:query": "pnpm --filter @playground/obsidian-memory rag:query",
    "rag:test": "pnpm --filter @playground/obsidian-memory rag:test",
    "rag:verify": "pnpm --filter @playground/obsidian-memory rag:verify",
    "rag:write": "pnpm --filter @playground/obsidian-memory rag:write",
    "ctrl:daemon": "npx @bulletproof-sh/ctrl-daemon@latest --force",
    "test": "turbo test",
    "test:integration": "pnpm --filter @playground/todo-app test:integration",
    "type-lint": "turbo type-lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "agents:check": "node scripts/agent-setup-check.mjs",
    "skills:list": "pnpm --filter @playground/agent-skills run agent-skills -- list",
    "skills:search": "pnpm --filter @playground/agent-skills run agent-skills -- search",
    "skills:route": "pnpm --filter @playground/agent-skills run agent-skills -- route",
    "skills:read": "pnpm --filter @playground/agent-skills run agent-skills -- read",
    "skills:registry": "pnpm --filter @playground/agent-skills run agent-skills -- registry",
    "skills:metadata-hook": "pnpm --filter @playground/agent-skills run skills:metadata-hook",
    "ralph:init": "node scripts/ralph/init.mjs",
    "ralph:loop": "node scripts/ralph/loop.mjs",
    "prepare": "husky install"
  },
  "devDependencies": {
    "astrograph": "0.3.1-alpha.74",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.17.0",
    "prettier": "^3.3.0",
    "tsup": "^8.5.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "workspace-tools": "^0.41.4"
  }
}
