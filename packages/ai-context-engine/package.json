{
  "name": "@playground/ai-context-engine",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Local deterministic context engine for AI-assisted code exploration",
  "bin": {
    "ai-context-engine": "./scripts/ai-context-engine.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "cli": "node --experimental-strip-types ./src/cli.ts",
    "mcp": "node --experimental-strip-types ./src/mcp.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:mutation": "node ./scripts/mutation-opt-in.mjs",
    "test:mutation:full": "node ./scripts/mutation-opt-in.mjs full",
    "mutation:smoke": "node ./scripts/run-stryker.mjs stryker.config.json",
    "mutation:full": "node ./scripts/run-stryker.mjs stryker.full.config.json"
  },
  "devDependencies": {
    "@playground/tsconfig": "workspace:*",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.10.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "tree-sitter": "0.21.1",
    "tree-sitter-javascript": "0.23.1",
    "tree-sitter-typescript": "0.23.2"
  }
}
